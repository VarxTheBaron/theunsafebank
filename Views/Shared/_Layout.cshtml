<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Suverän Bank</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <table width="100%" border="0" cellpadding="0" cellspacing="0">
        <tr>
            <td bgcolor="#003366" height="80">
                <center>
                    <font color="white" size="6"><b>Suverän Bank</b></font>
                    <br />
                    <font color="#ffcc00" size="2"><i>Dina suveräna pengar sedan 1998</i></font>
                </center>
            </td>
        </tr>
    </table>

    <table width="100%" border="0" cellpadding="20">
        <tr>
            <td>
                @RenderBody()
            </td>
        </tr>
    </table>

    <hr>

    <center>
        <font size="1" color="#666666">
            &copy; 1998-2026 Suverän Bank LLT | <i>Denna bank är medvetet total osäker i utbildningssyfte. Sätt inte in
            dina riktiga pengar här, då är det bättre att du swishar din lärare direkt.</i>
        </font>
    </center>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>